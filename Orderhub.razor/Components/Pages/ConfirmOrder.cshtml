@page
@model ConfirmOrderModel

<h1>Order for @Model.SchoolName</h1>

<form method="post" id="confirm-order-form">
    @Html.AntiForgeryToken()

    <table class="order-table">
        <thead>
            <tr>
                <th>SKU</th>
                <th>Embroidery</th>
                <th>Unit Price</th>
                <th>Quantity</th>
                <th>Line Total</th>
            </tr>
        </thead>

        <tbody>
            @for (var i = 0; i < Model.Lines.Count; i++)
            {
                var line = Model.Lines[i];

                <tr class="order-line"
                    data-unit-price="@line.UnitPrice">

                    <td>
                        @line.Sku
                        <input type="hidden" asp-for="Lines[i].Id" />
                        <input type="hidden" asp-for="Lines[i].Sku" />
                        <input type="hidden" asp-for="Lines[i].UnitPrice" />
                    </td>

                    <td>
                        @line.Embroidery
                        <input type="hidden" asp-for="Lines[i].Embroidery" />
                    </td>

                    <td>
                        £@line.UnitPrice.ToString("0.00")
                    </td>

                    <td>
                        <input asp-for="Lines[i].Quantity"
                               class="quantity-input"
                               type="number"
                               min="0"
                               step="1" />
                    </td>

                    <td>
                        £<span class="line-total">
                            @((line.UnitPrice * line.Quantity).ToString("0.00"))
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="subtotal">
        Subtotal: £<span id="subtotal">@Model.Subtotal.ToString("0.00")</span>
    </div>

    <button type="submit">Confirm</button>
</form>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const quantityInputs = document.querySelectorAll(".quantity-input");
            const subtotalElement = document.getElementById("subtotal");

            function formatMoney(value) {
                return Number(value).toFixed(2);
            }

            function recalculateSubtotal() {
                let subtotal = 0;

                document.querySelectorAll(".order-line").forEach(row => {
                    const unitPrice = Number(row.dataset.unitPrice);
                    const quantityInput = row.querySelector(".quantity-input");
                    const lineTotalElement = row.querySelector(".line-total");

                    const quantity = Number(quantityInput.value || 0);
                    const lineTotal = unitPrice * quantity;

                    lineTotalElement.textContent = formatMoney(lineTotal);
                    subtotal += lineTotal;
                });

                subtotalElement.textContent = formatMoney(subtotal);
            }

            quantityInputs.forEach(input => {
                input.addEventListener("input", recalculateSubtotal);
            });
        });
    </script>
}